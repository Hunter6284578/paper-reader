# 论文阅读器服务端环境变量
# 复制本文件为 .env 并填入真实值；.env 不提交到 git
# 部署时 .env 放在服务器 /opt/paper-reader/.env，docker-compose 会自动读取

# --- 必填 ---
# DeepSeek API Key（在 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=

# --- 安全相关（生产环境必须修改）---
# JWT 签名密钥，用 `openssl rand -hex 32` 生成
JWT_SECRET=
# 设置项加密密钥（用于加密存储的 API Key 等），用 `openssl rand -hex 32` 生成
SETTINGS_ENCRYPTION_KEY=
# 设备配对码（首次配对时使用，配对后可留空）
DEVICE_PAIRING_CODE=

# --- 可选（有默认值）---
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
JWT_EXPIRES_IN=7d

# 注意：RAG 检索已切换为纯 FTS5 关键词搜索，不再需要 SiliconFlow Embedding API

# 服务配置
PORT=3000
NODE_ENV=production
DATA_DIR=./data

# 词典 API
DICT_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en
