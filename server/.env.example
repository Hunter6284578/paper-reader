# 服务配置
PORT=3000
NODE_ENV=development
DATA_DIR=./data
MIGRATIONS_DIR=./src/db/migrations

# JWT 认证（生产环境请更换为随机字符串）
# 生成方法: openssl rand -hex 32
JWT_SECRET=your-secret-key-change-me
JWT_EXPIRES_IN=7d
DEVICE_TOKEN_EXPIRES_IN=180d

# 设置项加密密钥（用于加密存储的 API Key 等）
# 生成方法: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=your-encryption-key-change-me

# 设备配对码（首次配对时使用，配对后可留空）
DEVICE_PAIRING_CODE=
MAX_UPLOAD_BYTES=104857600
MAX_PROCESSING_ATTEMPTS=3

# DeepSeek API（AI 问答功能）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# SiliconFlow Embedding API（向量语义检索，免费注册: https://cloud.siliconflow.cn）
SILICONFLOW_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3

# 词典 API
DICT_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en
