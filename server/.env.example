# 服务配置
PORT=3000
NODE_ENV=development
DATA_DIR=./data

# JWT 认证（生产环境请更换为随机字符串）
# 生成方法: openssl rand -hex 32
JWT_SECRET=your-secret-key-change-me
JWT_EXPIRES_IN=7d

# 设置项加密密钥（用于加密存储的 API Key 等）
# 生成方法: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=your-encryption-key-change-me

# 设备配对码（首次配对时使用，配对后可留空）
DEVICE_PAIRING_CODE=

# DeepSeek API（AI 问答功能）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 注意：RAG 检索已切换为纯 FTS5 关键词搜索，不再需要 SiliconFlow Embedding API

# 词典 API
DICT_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en
